---
import BaseLayout from "../layouts/BaseLayout.astro";

const steps = [
  {
    step: "01",
    title: "オーナー登録",
    description: "農園の区画と焙煎タイプを選び、参加をスタート。",
  },
  {
    step: "02",
    title: "育成レポート",
    description: "季節の写真、栽培ノート、気候の変化を共有。",
  },
  {
    step: "03",
    title: "収穫とお届け",
    description: "年に一度、あなたの区画から生まれた豆が届きます。",
  },
];

const perks = [
  "限定ロットの先行案内",
  "農園訪問の優先予約",
  "ブリューノートの共有",
];
---

<BaseLayout title="Ownership | UNTFIELD COFFEE">
  <section class="mx-auto w-full max-w-7xl px-6 py-20 md:py-24">
    <div class="grid items-center gap-12 md:grid-cols-[1.1fr_0.9fr]">
      <div data-reveal>
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-[#1f4d3a]">Ownership</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-[#1a1a1a] md:text-5xl">
          育てることに参加する、年に一度の贈りもの
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-black/70">
          農園の時間と季節を共有し、収穫までのストーリーを一緒に育てます。
        </p>
        <div class="mt-6 flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-black/60">
          {perks.map((perk) => (
            <span class="rounded-full border border-black/10 bg-white/70 px-4 py-2">{perk}</span>
          ))}
        </div>
      </div>
      <img
        src="https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1200&q=80"
        alt="農園の作業"
        class="h-[420px] w-full rounded-[32px] object-cover shadow-[0_35px_60px_-45px_rgba(26,26,26,0.85)]"
        data-reveal
      />
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-28">
    <div class="grid gap-6 md:grid-cols-3" data-reveal>
      {steps.map((step) => (
        <div class="hover-lift rounded-3xl border border-black/5 bg-white/80 p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.3em] text-black/40">{step.step}</p>
          <h2 class="mt-3 text-xl font-semibold text-[#1a1a1a]">{step.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-black/60">{step.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
