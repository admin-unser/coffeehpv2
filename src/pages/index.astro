---
import BaseLayout from "../layouts/BaseLayout.astro";

const hero = {
  title: "世界自然遺産・やんばるの森で栽培する有機珈琲豆",
  subtitle:
    "森の湿度、霧、土壌の豊かさを味に写した希少な豆を、丁寧な焙煎とストーリーで届けます。",
};

const trustBadges = ["国産", "有機", "参加型"];

const features = [
  {
    title: "森と共生する栽培",
    description: "樹木と共に育つシェードグロウン。自然の循環を守りながら育てます。",
  },
  {
    title: "小ロット焙煎",
    description: "農園ごと、季節ごとの個性を引き出すために少量ずつ焙煎します。",
  },
  {
    title: "トレーサビリティ",
    description: "生産者、ロット、収穫年まで追える透明性で、安心と信頼を約束。",
  },
];

const beans = [
  {
    name: "Yambaru Mist",
    note: "柑橘と黒糖の甘い余韻",
    origin: "Okinawa, Japan",
    image:
      "https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&fit=crop&w=900&q=80",
  },
  {
    name: "Forest Reserve",
    note: "森林のハーブとカカオ",
    origin: "Yambaru Estate",
    image:
      "https://images.unsplash.com/photo-1447933601403-0c6688de566e?auto=format&fit=crop&w=900&q=80",
  },
  {
    name: "Dawn Harvest",
    note: "白い花と蜂蜜",
    origin: "Northern Farm",
    image:
      "https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=900&q=80",
  },
];

const ownershipSteps = [
  {
    step: "01",
    title: "申し込み",
    description: "農園の区画を選び、オーナーとして登録します。",
  },
  {
    step: "02",
    title: "生育レポート",
    description: "季節ごとの育成状況を写真とストーリーで共有。",
  },
  {
    step: "03",
    title: "収穫とお届け",
    description: "年に一度、あなたの区画から届く豆を体験。",
  },
];

const posts = [
  {
    category: "栽培便り",
    date: "2024.06.20",
    title: "森の雨と土壌が豆に与える香り",
    excerpt: "やんばるの雨季に訪れる微細な霧が、豆の甘さをどう変えるのか。",
    image:
      "https://images.unsplash.com/photo-1501339847302-ac426a4a7cbb?auto=format&fit=crop&w=900&q=80",
  },
  {
    category: "研究ノート",
    date: "2024.05.11",
    title: "有機栽培とポリフェノール含有量",
    excerpt: "論文ベースの知見を読み解き、身体への恩恵を整理します。",
    image:
      "https://images.unsplash.com/photo-1442512595331-e89e73853f31?auto=format&fit=crop&w=900&q=80",
  },
  {
    category: "ストーリー",
    date: "2024.04.02",
    title: "農園主の記憶と植え替えの季節",
    excerpt: "初めて苗木を植えた日から今日までの、静かな物語。",
    image:
      "https://images.unsplash.com/photo-1505976378723-9726b54e9bb9?auto=format&fit=crop&w=900&q=80",
  },
];
---

<BaseLayout title="UNTFIELD COFFEE" description={hero.title}>
  <section class="mx-auto w-full max-w-7xl px-6 py-20 md:py-28">
    <div class="grid items-center gap-12 md:grid-cols-[1.1fr_0.9fr]">
      <div data-reveal>
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-[#1f4d3a]">
          Yambaru Organic Estate
        </p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-[#1a1a1a] md:text-5xl">
          {hero.title}
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-black/70">{hero.subtitle}</p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a
            href="/ownership"
            class="rounded-full bg-[#1f4d3a] px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_35px_-25px_rgba(31,77,58,0.9)] transition hover:-translate-y-0.5 hover:bg-[#183d2f]"
          >
            オーナー制度を見る
          </a>
          <a
            href="/beans"
            class="rounded-full border border-[#1f4d3a]/30 bg-white px-6 py-3 text-sm font-semibold text-[#1f4d3a] transition hover:-translate-y-0.5 hover:border-[#1f4d3a]"
          >
            豆について
          </a>
          <a
            href="/blog"
            class="rounded-full px-4 py-2 text-sm font-semibold text-black/60 transition hover:text-[#1f4d3a]"
          >
            見聞録を読む
          </a>
        </div>
        <div class="mt-8 flex flex-wrap gap-3 text-xs font-semibold uppercase tracking-[0.2em] text-black/60">
          {trustBadges.map((badge) => (
            <span class="rounded-full border border-black/10 bg-white/70 px-4 py-2">{badge}</span>
          ))}
        </div>
      </div>
      <div class="relative" data-reveal>
        <div class="absolute -top-6 left-6 rounded-full bg-white/90 px-4 py-2 text-xs font-semibold uppercase tracking-[0.25em] text-[#1f4d3a] shadow">
          Farm to Cup
        </div>
        <img
          src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?auto=format&fit=crop&w=1200&q=80"
          alt="やんばるの森とコーヒー"
          class="h-[420px] w-full rounded-[32px] object-cover shadow-[0_35px_60px_-45px_rgba(26,26,26,0.85)] transition duration-500 hover:scale-[1.02]"
        />
        <div class="absolute -bottom-10 right-8 w-64 rounded-2xl border border-white/60 bg-white/90 p-4 shadow-xl backdrop-blur">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-black/50">Ownership</p>
          <p class="mt-2 text-sm font-semibold text-[#1a1a1a]">
            年1回、あなたの区画から届く限定豆
          </p>
          <p class="mt-1 text-xs leading-relaxed text-black/60">
            生育レポートとともに育てる体験を。
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-20">
    <div class="grid gap-8 md:grid-cols-3" data-reveal>
      {features.map((feature) => (
        <div class="hover-lift rounded-3xl border border-black/5 bg-white/80 p-8 shadow-[0_20px_40px_-35px_rgba(26,26,26,0.6)]">
          <h3 class="text-xl font-semibold text-[#1a1a1a]">{feature.title}</h3>
          <p class="mt-3 text-sm leading-relaxed text-black/60">{feature.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-24">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-black/40">Beans</p>
        <h2 class="mt-3 text-3xl font-semibold text-[#1a1a1a]">香りが語る、森の個性</h2>
      </div>
      <a href="/beans" class="text-sm font-semibold text-[#1f4d3a]">豆のラインナップを見る →</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3" data-reveal>
      {beans.map((bean) => (
        <article class="hover-lift overflow-hidden rounded-3xl border border-black/5 bg-white/80">
          <img src={bean.image} alt={bean.name} class="h-48 w-full object-cover transition duration-700 hover:scale-[1.05]" />
          <div class="p-6">
            <p class="text-xs uppercase tracking-[0.2em] text-black/40">{bean.origin}</p>
            <h3 class="mt-2 text-xl font-semibold text-[#1a1a1a]">{bean.name}</h3>
            <p class="mt-2 text-sm text-black/60">{bean.note}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-24">
    <div class="grid gap-10 md:grid-cols-[1.1fr_0.9fr]" data-reveal>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-black/40">Ownership</p>
        <h2 class="mt-3 text-3xl font-semibold text-[#1a1a1a]">参加して育てる、年に一度の収穫</h2>
        <p class="mt-4 text-sm leading-relaxed text-black/60">
          オーナー制度は単なる定期便ではなく、農園の一年に寄り添う体験です。
        </p>
        <a
          href="/ownership"
          class="mt-6 inline-flex items-center rounded-full border border-[#1f4d3a]/30 bg-white px-5 py-2 text-sm font-semibold text-[#1f4d3a] transition hover:-translate-y-0.5 hover:border-[#1f4d3a]"
        >
          詳しく見る
        </a>
      </div>
      <div class="space-y-4">
        {ownershipSteps.map((step) => (
          <div class="hover-lift rounded-2xl border border-black/5 bg-white/80 p-6">
            <p class="text-xs font-semibold uppercase tracking-[0.3em] text-black/40">{step.step}</p>
            <h3 class="mt-2 text-lg font-semibold text-[#1a1a1a]">{step.title}</h3>
            <p class="mt-2 text-sm text-black/60">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-24">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between" data-reveal>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-black/40">Journal</p>
        <h2 class="mt-3 text-3xl font-semibold text-[#1a1a1a]">見聞録: 栽培と香りの記録</h2>
      </div>
      <a href="/blog" class="text-sm font-semibold text-[#1f4d3a]">記事一覧へ →</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3" data-reveal>
      {posts.map((post) => (
        <article class="hover-lift overflow-hidden rounded-3xl border border-black/5 bg-white/80">
          <img src={post.image} alt={post.title} class="h-44 w-full object-cover transition duration-700 hover:scale-[1.04]" />
          <div class="p-6">
            <p class="text-xs uppercase tracking-[0.2em] text-black/40">
              {post.category} · {post.date}
            </p>
            <h3 class="mt-2 text-lg font-semibold text-[#1a1a1a]">{post.title}</h3>
            <p class="mt-2 text-sm text-black/60">{post.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-28">
    <div class="grid gap-10 rounded-[32px] border border-black/5 bg-white/80 p-10 md:grid-cols-[1.1fr_0.9fr]" data-reveal>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.35em] text-black/40">Contact</p>
        <h2 class="mt-3 text-3xl font-semibold text-[#1a1a1a]">農園の訪問、ギフト、法人向けのご相談</h2>
        <p class="mt-4 text-sm leading-relaxed text-black/60">
          コラボレーションやギフトのご相談など、お気軽にお問い合わせください。
        </p>
      </div>
      <div class="flex flex-col items-start justify-center gap-4">
        <a
          href="/contact"
          class="rounded-full bg-[#1f4d3a] px-6 py-3 text-sm font-semibold text-white shadow-[0_18px_35px_-25px_rgba(31,77,58,0.9)] transition hover:-translate-y-0.5 hover:bg-[#183d2f]"
        >
          お問い合わせ
        </a>
        <p class="text-xs uppercase tracking-[0.2em] text-black/40">response within 48 hours</p>
      </div>
    </div>
  </section>
</BaseLayout>
