---
import BaseLayout from "../layouts/BaseLayout.astro";

const highlights = [
  {
    title: "シェードグロウン",
    description: "森の樹木と共に育つことで、苦味が穏やかな豆に育ちます。",
  },
  {
    title: "山あいの微気候",
    description: "霧と雨が交差する環境が、香りの層を深めます。",
  },
  {
    title: "循環型の土壌",
    description: "落ち葉や有機堆肥を活かし、土の微生物を守ります。",
  },
];

const gallery = [
  "https://images.unsplash.com/photo-1502082553048-f009c37129b9?auto=format&fit=crop&w=900&q=80",
  "https://images.unsplash.com/photo-1494859802809-d069c3b71a8e?auto=format&fit=crop&w=900&q=80",
  "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=900&q=80",
];
---

<BaseLayout title="Farm | UNTFIELD COFFEE">
  <section class="mx-auto w-full max-w-7xl px-6 py-20 md:py-24">
    <div class="grid items-center gap-12 md:grid-cols-[1.1fr_0.9fr]">
      <div data-reveal>
        <p class="text-xs font-semibold uppercase tracking-[0.4em] text-[#1f4d3a]">Farm</p>
        <h1 class="mt-4 text-4xl font-semibold leading-tight text-[#1a1a1a] md:text-5xl">
          森と共生する、やんばるのコーヒーファーム
        </h1>
        <p class="mt-5 text-lg leading-relaxed text-black/70">
          世界自然遺産に認定された森で、日陰栽培と水資源の保全を両立。
        </p>
      </div>
      <img
        src="https://images.unsplash.com/photo-1500534314209-a26db0f5c4a0?auto=format&fit=crop&w=1200&q=80"
        alt="やんばるの森の風景"
        class="h-[420px] w-full rounded-[32px] object-cover shadow-[0_35px_60px_-45px_rgba(26,26,26,0.85)]"
        data-reveal
      />
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-24">
    <div class="grid gap-6 md:grid-cols-3" data-reveal>
      {highlights.map((item) => (
        <div class="hover-lift rounded-3xl border border-black/5 bg-white/80 p-8">
          <h2 class="text-xl font-semibold text-[#1a1a1a]">{item.title}</h2>
          <p class="mt-3 text-sm leading-relaxed text-black/60">{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="mx-auto w-full max-w-7xl px-6 pb-28">
    <div class="grid gap-6 md:grid-cols-3" data-reveal>
      {gallery.map((image, index) => (
        <div class="overflow-hidden rounded-3xl border border-black/5 bg-white/80">
          <img
            src={image}
            alt={`農園の風景 ${index + 1}`}
            class="h-64 w-full object-cover transition duration-700 hover:scale-[1.05]"
          />
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
