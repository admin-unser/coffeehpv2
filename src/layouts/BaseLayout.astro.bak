---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - UNTFIELD COFFEE</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body class="min-h-screen bg-white text-charcoal antialiased">
    <header class="border-b border-cream-200 bg-white shadow-sm">
      <nav class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="text-lg font-semibold text-forest-700 hover:text-forest-800 transition-colors">
          UNTFIELD COFFEE
        </a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="mt-20 border-t border-cream-200 bg-cream-100 py-8">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <p class="text-center text-sm text-charcoal">
          © {new Date().getFullYear()} UNTFIELD COFFEE
        </p>
      </div>
    </footer>
  </body>
</html>

