---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";

const cards = [
  {
    title: "農園について",
    desc: "やんばるの森で育つ、有機国産コーヒー。栽培と循環の取り組み。",
    href: "/ja/farm",
    icon: "🌳",
  },
  {
    title: "生豆・焙煎豆",
    desc: "生豆・焙煎豆のご相談はこちら。準備中でもお問い合わせ導線でOK。",
    href: "/ja/beans",
    icon: "☕",
  },
];
---

<BaseLayout title="UNTFIELD COFFEE">
  <!-- Hero Section -->
  <section class="bg-gradient-to-b from-cream-50 to-white mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-2 lg:gap-12 items-center">
      <!-- Left: Copy & CTA -->
      <div class="space-y-6 lg:space-y-8">
        <div>
          <p class="text-sm font-medium tracking-wider text-forest-600 uppercase mb-4">
            ORGANIC JAPANESE COFFEE • YANBARU
          </p>
          <h1 class="text-4xl font-bold leading-tight text-charcoal sm:text-5xl lg:text-6xl">
            世界自然遺産・やんばるの森で育つ、<span class="text-forest-700">有機国産コーヒー</span>
          </h1>
        </div>
        <p class="text-lg leading-relaxed text-charcoal sm:text-xl">
          森とともに育て、豆の背景まで届ける。生豆・焙煎豆、そして「育てる物語」に参加できるオーナー制度。
        </p>
          <div class="flex flex-wrap gap-4 pt-4">
            <a
              href="/ja/farm"
              class="inline-flex items-center justify-center rounded-full bg-forest-600 px-6 py-3 text-sm font-semibold text-white shadow-md hover:bg-forest-700 transition-colors"
            >
              農園について
            </a>
            <a
              href="/ja/blog"
              class="inline-flex items-center justify-center rounded-full border-2 border-coffee-600 bg-white px-6 py-3 text-sm font-semibold text-coffee-800 hover:bg-coffee-50 hover:text-coffee-900 transition-colors"
            >
              見聞録を読む
            </a>
            <a
              href="/ja/contact"
              class="inline-flex items-center justify-center rounded-full border-2 border-charcoal/20 bg-white px-6 py-3 text-sm font-semibold text-charcoal hover:bg-charcoal/5 transition-colors"
            >
              お問い合わせ
            </a>
          </div>
        </div>
        <!-- Right: Image Placeholder -->
        <div class="relative aspect-square lg:aspect-auto lg:h-[600px] rounded-2xl overflow-hidden shadow-2xl bg-gradient-to-br from-forest-700 to-forest-900">
          <div class="absolute inset-0 flex items-center justify-center text-white/20">
            <svg class="w-64 h-64" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
            </svg>
          </div>
          <div class="absolute bottom-4 left-4 right-4 text-white text-sm text-center">
            やんばるの森の写真
          </div>
        </div>
      </div>
    </section>

  <!-- Cards Section -->
  <section class="bg-white mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="grid gap-6 sm:grid-cols-2 lg:gap-8">
      {cards.map((c) => (
        <a
          href={c.href}
          class="group rounded-2xl border-2 border-cream-300 bg-white p-8 shadow-md hover:shadow-xl hover:border-forest-400 transition-all duration-300"
        >
          <div class="text-4xl mb-4">{c.icon}</div>
          <h2 class="text-2xl font-bold text-charcoal mb-3 group-hover:text-forest-700 transition-colors">
            {c.title}
          </h2>
          <p class="text-charcoal leading-relaxed mb-4">
            {c.desc}
          </p>
          <span class="inline-flex items-center text-sm font-medium text-forest-600 group-hover:text-forest-700 transition-colors">
            詳しく見る →
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Ownership Highlight Section -->
  <section class="bg-cream-50 mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="rounded-3xl bg-gradient-to-br from-forest-600 to-forest-800 p-8 sm:p-12 lg:p-16 text-white shadow-2xl">
      <div class="max-w-3xl space-y-6">
        <div class="text-5xl mb-4">🌿</div>
        <h2 class="text-3xl font-bold sm:text-4xl lg:text-5xl leading-tight">
          コーヒーノ木オーナーシップ
        </h2>
        <p class="text-lg sm:text-xl leading-relaxed text-white">
          コーヒーを"買う"のではなく"育てる物語に参加する"制度。<br />
          やんばるの森で育つコーヒーノ木をオーナーとして所有し、収穫から焙煎まで、コーヒーができるまでの物語を一緒に体験できます。
        </p>
        <p class="text-base sm:text-lg text-white/90 pt-2">
          ※ 年1回、収穫した豆をお届けします
        </p>
        <div class="pt-6">
          <a
            href="/ja/ownership"
            class="inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-semibold text-forest-700 shadow-lg hover:bg-cream-50 transition-colors"
          >
            オーナー制度について
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Blog Teaser Section -->
  <section class="bg-white mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <div class="rounded-2xl border-2 border-cream-300 bg-white p-8 sm:p-10 lg:p-12 shadow-md">
      <h3 class="text-2xl font-bold text-charcoal mb-4 sm:text-3xl">
        コーヒー知ろうと見聞録
      </h3>
      <p class="text-lg leading-relaxed text-charcoal mb-6 sm:text-xl">
        栽培・季節便り、コーヒーの歴史、論文ベースの効能、用語辞典。<br />
        "知るほどにおいしくなる"コーヒーの背景を発信します。
      </p>
      <a
        href="/ja/blog"
        class="inline-flex items-center justify-center rounded-full border-2 border-coffee-600 bg-white px-6 py-3 text-sm font-semibold text-coffee-800 hover:bg-coffee-50 hover:text-coffee-900 transition-colors"
      >
        ブログ一覧へ →
      </a>
    </div>
  </section>
</BaseLayout>
